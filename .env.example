# ============================================
# PlantGeo Environment Configuration
# Copy this file to .env.local and fill in values.
# Never commit .env.local or any file with real secrets.
# ============================================

# --------------------------------------------
# Database
# --------------------------------------------
POSTGRES_PASSWORD=geopass
DATABASE_URL=postgresql://geo:geopass@localhost:5432/plantgeo

# --------------------------------------------
# Redis
# --------------------------------------------
REDIS_URL=redis://localhost:6379

# --------------------------------------------
# Martin Tile Server
# --------------------------------------------
MARTIN_URL=http://localhost:3100

# --------------------------------------------
# Valhalla Routing
# --------------------------------------------
VALHALLA_URL=http://localhost:8002
VALHALLA_PBF_URL=https://download.geofabrik.de/north-america/us/california-latest.osm.pbf

# --------------------------------------------
# Photon Geocoder
# --------------------------------------------
PHOTON_URL=http://localhost:2322

# --------------------------------------------
# Cloudflare R2 (PMTiles storage)
# --------------------------------------------
R2_BUCKET=plantgeo-tiles
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# --------------------------------------------
# Public tile URLs (Next.js client-side)
# --------------------------------------------
NEXT_PUBLIC_PMTILES_URL=https://your-r2-bucket.r2.dev/basemap.pmtiles
NEXT_PUBLIC_TERRAIN_URL=https://s3.amazonaws.com/elevation-tiles-prod/terrarium/{z}/{x}/{y}.png
NEXT_PUBLIC_MAP_STYLE_URL=http://localhost:3100/style.json

# --------------------------------------------
# Auth (NextAuth.js)
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
# --------------------------------------------
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# OAuth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --------------------------------------------
# External APIs
# --------------------------------------------
MAPILLARY_ACCESS_TOKEN=
NASA_FIRMS_KEY=

# --------------------------------------------
# PlantCommerce Integration (Track 28)
# --------------------------------------------
# Base URL of the PlantCommerce API (e.g. https://plantcommerce.example.com)
PLANTCOMMERCE_API_URL=
# Secret used to sign priority-zone webhook payloads (HMAC-SHA256)
PLANTCOMMERCE_WEBHOOK_URL=
PLANTCOMMERCE_WEBHOOK_SECRET=
# Admin API token for API key management endpoints
ADMIN_API_TOKEN=

# --------------------------------------------
# Anthropic AI (Track 31 — AI Regional Intelligence)
# --------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
