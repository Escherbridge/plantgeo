# ============================================
# PlantGeo Environment Configuration
# Copy this file to .env.local and fill in values.
# Never commit .env.local or any file with real secrets.
# ============================================

# ============================================
# DATABASE
# ============================================

# PostgreSQL password — used by Docker Compose to init the database container.
# Must match the password in DATABASE_URL below.
# Required for local Docker dev.
POSTGRES_PASSWORD=geopass

# Full PostgreSQL connection string (PostGIS + TimescaleDB).
# Required. Railway injects this automatically when you attach a Postgres plugin.
DATABASE_URL=postgresql://geo:geopass@localhost:5432/plantgeo

# ============================================
# REDIS
# ============================================

# Redis connection URL for caching, pub/sub, and BullMQ job queues.
# Required. Railway injects this automatically when you attach a Redis plugin.
REDIS_URL=redis://localhost:6379

# ============================================
# TILE SERVER (Martin)
# ============================================

# Base URL of the Martin tile server (serves PostGIS + PMTiles + MBTiles).
# Required for dynamic overlay tiles (vector tiles from PostGIS).
# Local default: http://localhost:3100
MARTIN_URL=http://localhost:3100

# ============================================
# PUBLIC MAP TILE URLS (Next.js client-side)
# NEXT_PUBLIC_ prefix required — these are exposed to the browser.
# ============================================

# URL of the basemap PMTiles file hosted on Cloudflare R2 or similar CDN.
# Required. Example: https://your-account.r2.dev/basemap.pmtiles
NEXT_PUBLIC_PMTILES_URL=https://your-r2-bucket.r2.dev/basemap.pmtiles

# URL template for terrain/elevation tiles (used for 3D terrain in MapLibre).
# Optional. Defaults to the AWS Open Data terrain tileset.
NEXT_PUBLIC_TERRAIN_URL=https://s3.amazonaws.com/elevation-tiles-prod/terrarium/{z}/{x}/{y}.png

# URL of the MapLibre style JSON served by Martin.
# Required for the map to load styles and tile sources.
NEXT_PUBLIC_MAP_STYLE_URL=http://localhost:3100/style.json

# Public base URL of the deployed app (used in emails and embeds).
# Required for production. Example: https://plantgeo.io
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# CLOUDFLARE R2 (PMTiles storage)
# Used server-side for tile uploads/ingestion and pre-signed URLs.
# Get credentials from: https://dash.cloudflare.com/ -> R2 -> Manage API tokens
# ============================================

# Name of the R2 bucket holding PMTiles and MBTiles files.
# Required for tile ingestion scripts.
R2_BUCKET=plantgeo-tiles

# R2 S3-compatible endpoint. Replace <ACCOUNT_ID> with your Cloudflare account ID.
# Required for tile ingestion scripts.
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com

# R2 API token key ID. Required for tile ingestion scripts.
R2_ACCESS_KEY_ID=

# R2 API token secret. Required for tile ingestion scripts.
R2_SECRET_ACCESS_KEY=

# ============================================
# ROUTING (Valhalla)
# ============================================

# Base URL of the Valhalla routing engine (multi-modal, isochrones, turn-by-turn).
# Required for routing features. Local default: http://localhost:8002
VALHALLA_URL=http://localhost:8002

# PBF source file URL for building the Valhalla routing graph.
# Required when bootstrapping Valhalla. Download region-specific files from Geofabrik.
# Get from: https://download.geofabrik.de/
VALHALLA_PBF_URL=https://download.geofabrik.de/north-america/us/california-latest.osm.pbf

# ============================================
# GEOCODING (Photon)
# ============================================

# Base URL of the Photon geocoder (autocomplete + reverse geocoding via Nominatim).
# Required for search features. Local default: http://localhost:2322
PHOTON_URL=http://localhost:2322

# ============================================
# AUTH (NextAuth.js)
# ============================================

# Random secret used to sign NextAuth session tokens and JWTs.
# Required in production. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Canonical URL of your deployment (used for OAuth callback URLs).
# Required. Must match the redirect URIs configured in your OAuth apps.
NEXTAUTH_URL=http://localhost:3000

# Google OAuth credentials.
# Optional. Get from: https://console.cloud.google.com/ -> APIs & Services -> Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth credentials.
# Optional. Get from: https://github.com/settings/developers -> OAuth Apps
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ============================================
# EMAIL NOTIFICATIONS
# ============================================

# Email provider to use for sending alert and digest emails.
# Optional. Accepted values: "resend" | "sendgrid"
# If unset, emails are logged to console only (graceful degradation).
EMAIL_PROVIDER=

# Sender address shown in outgoing emails.
# Optional. Defaults to "PlantGeo Alerts <alerts@plantgeo.io>"
EMAIL_FROM=

# Resend API key. Required when EMAIL_PROVIDER=resend.
# Get from: https://resend.com/api-keys
RESEND_API_KEY=

# SendGrid API key. Required when EMAIL_PROVIDER=sendgrid.
# Get from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=

# ============================================
# EXTERNAL DATA APIs
# ============================================

# Mapillary access token (server-side) for fetching street-level imagery metadata.
# Optional. Get from: https://www.mapillary.com/developer/api-documentation/
MAPILLARY_ACCESS_TOKEN=

# Mapillary access token (client-side) for the StreetCoverage component.
# Optional. Must match MAPILLARY_ACCESS_TOKEN. Exposed to the browser.
NEXT_PUBLIC_MAPILLARY_ACCESS_TOKEN=

# NASA FIRMS API key for near-real-time fire detection data (VIIRS/MODIS).
# Required for fire layer features.
# Get from: https://firms.modaps.eosdis.nasa.gov/api/area/
NASA_FIRMS_KEY=

# ============================================
# INGEST LAYER IDs
# Override these only if your Martin/PostGIS setup uses non-default layer names.
# ============================================

# Layer ID for ingested active fire perimeters. Optional. Default: fire-perimeters-layer
FIRES_LAYER_ID=fire-perimeters-layer

# Layer ID for ingested IoT sensor readings. Optional. Default: sensors-layer
SENSORS_LAYER_ID=sensors-layer

# Layer ID for ingested NASA FIRMS fire detections. Optional. Default: fire-detections-layer
FIRMS_LAYER_ID=fire-detections-layer

# ============================================
# PLANTCOMMERCE INTEGRATION
# ============================================

# Base URL of the PlantCommerce API.
# Required for PlantCommerce integration (Track 28). Example: https://plantcommerce.example.com
PLANTCOMMERCE_API_URL=

# Webhook endpoint on the PlantCommerce side to push priority-zone updates to.
# Required for priority-zone webhook job.
PLANTCOMMERCE_WEBHOOK_URL=

# HMAC-SHA256 secret used to sign priority-zone webhook payloads.
# Required for priority-zone webhook job.
PLANTCOMMERCE_WEBHOOK_SECRET=

# ============================================
# ADMIN API
# ============================================

# Bearer token required to call admin-only API endpoints (e.g. /api/v1/admin/keys).
# Required in production. Generate with: openssl rand -hex 32
ADMIN_API_TOKEN=

# ============================================
# ANTHROPIC AI (Track 31 — AI Regional Intelligence)
# ============================================

# Anthropic API key for Claude-powered regional intelligence features.
# Required for AI features. Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Anthropic model ID to use for regional intelligence responses.
# Optional. Defaults to claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
