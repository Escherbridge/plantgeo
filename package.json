{
  "name": "plantgeo",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source 3D geospatial mapping platform with enterprise-grade architecture",
  "scripts": {
    "dev": "next dev --turbopack -p 3001",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "docker:up": "podman compose up -d",
    "docker:down": "podman compose down",
    "docker:logs": "podman compose logs -f",
    "tiles:serve": "podman compose up martin -d",
    "routing:serve": "podman compose up valhalla -d"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@auth/drizzle-adapter": "^1.11.1",
    "@deck.gl/core": "^9.1.0",
    "@deck.gl/geo-layers": "^9.1.0",
    "@deck.gl/layers": "^9.1.0",
    "@deck.gl/mapbox": "^9.1.0",
    "@deck.gl/react": "^9.1.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@tanstack/react-query": "^5.66.0",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.39.0",
    "ioredis": "^5.4.0",
    "jotai": "^2.12.0",
    "lucide-react": "^0.478.0",
    "maplibre-gl": "^5.2.0",
    "next": "^16.2.1",
    "next-auth": "^4.24.13",
    "pmtiles": "^4.2.0",
    "postgres": "^3.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "superjson": "^2.2.2",
    "tailwind-merge": "^3.0.0",
    "tailwindcss": "^4.0.0",
    "three": "^0.172.0",
    "zod": "^3.24.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.172.0",
    "drizzle-kit": "^0.30.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.2.0",
    "postcss": "^8.5.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
